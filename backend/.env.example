# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/nsrcel_db
# Supabase: postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nsrcel_db
DATABASE_SSL_USE_CERTIFI=true
DATABASE_SSL_INSECURE=false
REDIS_URL=redis://localhost:6379
GROQ_API_KEY=
INTERNAL_SECRET=secret-for-dev
# HS256 secret for /auth login tokens (defaults to INTERNAL_SECRET if empty — set a strong value in production).
AUTH_JWT_SECRET=
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Google OAuth Web client ID (must match NEXT_PUBLIC_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=
# Non-empty value required for "NSRCEL team" sign-ups (role admin).
ADMIN_INVITE_CODE=
# Dev: POST /auth/legacy-admin with username/password (default karthig / 1234). Set ALLOW_LEGACY_ADMIN=false in production.
ALLOW_LEGACY_ADMIN=true
LEGACY_ADMIN_USERNAME=karthig
LEGACY_ADMIN_PASSWORD=1234
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_VERIFY=false
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=
