# FastAPI base URL (no /api/v1) — used by Next.js rewrites in next.config.mjs
# Also used for Server Components (e.g. /programs) if INTERNAL_API_URL is unset.
BACKEND_ORIGIN=http://localhost:8000
# Pitch decks /uploads URLs in the UI
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000
# Optional: direct API base for server components (defaults work if same as BACKEND_ORIGIN)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Same Web client ID as backend GOOGLE_CLIENT_ID (Google Identity Services).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
